{
  "name": "tauri-app-test",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx servor ./dist index.html 1420 --reload",
    "build-plugins": "npx kui-application build-dependency -o ./dist/ui",
    "deploy-self": "cp ./index.html ./dist/index.html",
    "build": "npx tsc && sass ./src/plugins",
    "build-dist": "npm run clean && npm run build-plugins && npm run build && npm run rollup && npm run deploy-self",
    "lint": "npx tslint --project . && npx nplint",
    "tauri": "tauri",
    "tauri-dev": "npm run tauri dev -- --no-watch -- -- --no-keychain",
    "tauri-build": "npm run tauri -- -v build -b app -d",
    "clean": "npx rimraf -rf ./dist",
    "rollup": "npx cross-env NODE_ENV=development kui-application build -o ./dist/ui",
    "sass": "sass ./src/plugins -w -q --no-verbose",
    "rollup-watch": "npm run rollup -- -w",
    "start-messengers": "env RUST_BACKTRACE=full open -n ../../../target/debug/bundle/macos/CO\\ Messenger\\ Demo.app --args --no-keychain && open -n ../../../target/debug/bundle/macos/CO\\ Messenger\\ Demo.app --args --no-keychain --base-path ~/Library/Application\\ Support/co.app.1io2.co"
  },
  "files": [
    "**/*.css",
    "**/*.css.d.ts",
    "**/*.css.map",
    "**/*.d.ts",
    "**/*.js",
    "**/*.js.map",
    "assets/",
    "!**/.*",
    "!**/.*/**"
  ],
  "kui": {
    "plugin": {
      "coapp-chats-list": {
        "main": "./src/plugins/coapp-chatslist-plugin/plugin.tsx",
        "runtime": [
          "node",
          "browser"
        ]
      },
      "coapp-group-view": {
        "main": "./src/plugins/coapp-group-view-plugin/plugin.tsx",
        "runtime": [
          "node",
          "browser"
        ]
      },
      "coapp-messenger-view": {
        "main": "./src/plugins/coapp-messenger-view-plugin/plugin.tsx",
        "runtime": [
          "node",
          "browser"
        ]
      },
      "coapp-add-participant": {
        "main": "./src/plugins/group-view-add-participant-dialog-plugin/plugin.tsx",
        "runtime": [
          "node",
          "browser"
        ]
      },
      "coapp-leave-group": {
        "main": "./src/plugins/group-view-leave-group-dialog-plugin/plugin.tsx",
        "runtime": [
          "node",
          "browser"
        ]
      },
      "coapp-remove-participant": {
        "main": "./src/plugins/group-view-remove-participant-dialog-plugin/plugin.tsx",
        "runtime": [
          "node",
          "browser"
        ]
      }
    }
  },
  "dependencies": {
    "@1io/coapp-chatlist-view": "0.0.1-mr1.5",
    "@1io/coapp-messenger-view": "0.4.4-mr7.1",
    "@1io/coapp-style": "^0.1.3",
    "@1io/copy-paste-utils": "^0.3.9",
    "@1io/kui-application": "^0.5.0",
    "@1io/kui-application-sdk": "^5.0.1",
    "@1io/kui-badge": "^0.1.7",
    "@1io/kui-button": "^0.25.0",
    "@1io/kui-dialog": "^0.16.3",
    "@1io/kui-level-stack": "^0.6.16",
    "@1io/one2edit-default-icons": "^0.6.43",
    "@1io/packaging-utils": "^0.1.4",
    "@1io/redux-utils": "^0.9.3",
    "@babel/core": "^7.24.7",
    "@ipld/dag-cbor": "^9.2.0",
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-dialog": "^2.2.1",
    "@tauri-apps/plugin-fs": "^2.3.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@types/babel-core": "^6.25.10",
    "clsx": "^2.1.1",
    "ipfs-unixfs": "^11.2.1",
    "moment": "^2.30.1",
    "multiformats": "^13.1.1",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-redux": "^7.2.9",
    "react-router-dom": "^6.28.1",
    "redux": "^4.2.1",
    "rxjs": "^7.8.1",
    "sass": "^1.77.6",
    "tauri-plugin-co-sdk": "file:../../",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@1io/kui-form-common": "^0.20.6",
    "@1io/kui-form-context": "^0.2.0",
    "@1io/kui-icons": "^0.4.11",
    "@1io/kui-style": "^0.2.39",
    "@1io/nplint": "^0.2.28",
    "@1io/stylelint": "^0.2.7",
    "@1io/tslint": "^0.1.15",
    "@babel/core": "^7.16.0",
    "@tauri-apps/cli": "^2.4.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^16.18.101",
    "@types/react": "^16.8.6",
    "@types/react-dom": "^16.8.6",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "internal-ip": "^7.0.0",
    "servor": "^4.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "npm": "^8.0.0"
  },
  "exports": {
    ".": "./index.js"
  }
}
