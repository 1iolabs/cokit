// Project tasks configuration. See https://zed.dev/docs/tasks for documentation.
[
  {
    "label": "Npm install tauri",
    "command": "cd $ZED_WORKTREE_ROOT/tauri-plugin-co-sdk; npm install",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "dock",
    "hide": "on_success"
  },
  {
    "label": "Build tauri dist-js",
    "command": "cd $ZED_WORKTREE_ROOT/tauri-plugin-co-sdk; npm run build",
    "hide": "on_success"
  },
  {
    "label": "Generate json schemas and ts interfaces",
    "command": "$ZED_WORKTREE_ROOT/json-schemas/generate-ts.sh",
    "use_new_terminal": false,
    "reveal": "always",
    "hide": "on_success"
  },
  {
    "label": "Build builtin cores",
    "command": "cargo run --bin co-cli -- --no-keychain core build-builtin",
    "use_new_terminal": false,
    "reveal": "always",
    "hide": "on_success"
  }
]
