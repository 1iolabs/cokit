{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Key",
  "type": "object",
  "required": [
    "description",
    "name",
    "secret",
    "tags",
    "uri"
  ],
  "properties": {
    "description": {
      "description": "Key description.",
      "type": "string"
    },
    "name": {
      "description": "Key Name. Usually the service name.",
      "type": "string"
    },
    "secret": {
      "description": "The secret.",
      "allOf": [
        {
          "$ref": "#/definitions/Secret"
        }
      ]
    },
    "tags": {
      "description": "Optional tags.",
      "allOf": [
        {
          "$ref": "#/definitions/Tags"
        }
      ]
    },
    "uri": {
      "description": "URI which uniquely identifies this key.",
      "type": "string"
    }
  },
  "definitions": {
    "Cid": {
      "title": "Cid",
      "type": "object",
      "required": [
        "/"
      ],
      "properties": {
        "/": {
          "type": "string"
        }
      }
    },
    "Secret": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "Password"
          ],
          "properties": {
            "Password": {
              "$ref": "#/definitions/Secret2"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "PrivateKey"
          ],
          "properties": {
            "PrivateKey": {
              "$ref": "#/definitions/Secret2"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": [
            "SharedKey"
          ],
          "properties": {
            "SharedKey": {
              "$ref": "#/definitions/Secret2"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "Secret2": {
      "description": "Simple wrapper type for secrents to not escape them.",
      "type": "array",
      "items": {
        "type": "integer",
        "format": "uint8",
        "minimum": 0.0
      }
    },
    "TagValue": {
      "description": "Tag Value",
      "oneOf": [
        {
          "description": "Represents the absence of a value or the value undefined.",
          "type": "string",
          "enum": [
            "Null"
          ]
        },
        {
          "description": "Represents a boolean value.",
          "type": "object",
          "required": [
            "Bool"
          ],
          "properties": {
            "Bool": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Represents an integer.",
          "type": "object",
          "required": [
            "Integer"
          ],
          "properties": {
            "Integer": {
              "type": "integer",
              "format": "int128"
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Represents a floating point value.",
          "type": "object",
          "required": [
            "Float"
          ],
          "properties": {
            "Float": {
              "$ref": "#/definitions/double"
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Represents an UTF-8 string.",
          "type": "object",
          "required": [
            "String"
          ],
          "properties": {
            "String": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Represents a sequence of bytes.",
          "type": "object",
          "required": [
            "Bytes"
          ],
          "properties": {
            "Bytes": {
              "type": "array",
              "items": {
                "type": "integer",
                "format": "uint8",
                "minimum": 0.0
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Represents a list.",
          "type": "object",
          "required": [
            "List"
          ],
          "properties": {
            "List": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/TagValue"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Represents a map of strings.",
          "type": "object",
          "required": [
            "Map"
          ],
          "properties": {
            "Map": {
              "type": "object",
              "additionalProperties": {
                "$ref": "#/definitions/TagValue"
              }
            }
          },
          "additionalProperties": false
        },
        {
          "description": "Represents an IPLD Link structure, implemented with Cid's (Content Identifiers) For more information see: https://ipld.io/docs/data-model/kinds/#link-kind",
          "type": "object",
          "required": [
            "Link"
          ],
          "properties": {
            "Link": {
              "$ref": "#/definitions/Cid"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "Tags": {
      "description": "Tags.",
      "type": "array",
      "items": {
        "type": "array",
        "items": [
          {
            "type": "string"
          },
          {
            "$ref": "#/definitions/TagValue"
          }
        ],
        "maxItems": 2,
        "minItems": 2
      },
      "uniqueItems": true
    },
    "double": {
      "type": "number",
      "format": "double"
    }
  }
}